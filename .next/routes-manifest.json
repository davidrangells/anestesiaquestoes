{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/checkout/boas-vindas",
      "regex": "^/checkout/boas\\-vindas(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/checkout/boas\\-vindas(?:/)?$"
    },
    {
      "page": "/checkout/processando",
      "regex": "^/checkout/processando(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/checkout/processando(?:/)?$"
    },
    {
      "page": "/checkout/sucesso",
      "regex": "^/checkout/sucesso(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/checkout/sucesso(?:/)?$"
    },
    {
      "page": "/politica-de-privacidade",
      "regex": "^/politica\\-de\\-privacidade(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/politica\\-de\\-privacidade(?:/)?$"
    },
    {
      "page": "/termos-de-uso",
      "regex": "^/termos\\-de\\-uso(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/termos\\-de\\-uso(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}